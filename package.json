{
  "name": "claude-talkback-mcp",
  "version": "0.3.0",
  "description": "MCP server that gives Claude Code a conversational voice — speaks short, peer-style summaries aloud. Two engines (Windows SAPI + ElevenLabs), works from WSL and native Windows.",
  "license": "MIT",
  "author": "Cory Loriot",
  "homepage": "https://github.com/jarvann/claude-talkback-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarvann/claude-talkback-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jarvann/claude-talkback-mcp/issues"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "text-to-speech",
    "tts",
    "elevenlabs",
    "sapi",
    "voice",
    "wsl"
  ],
  "type": "module",
  "bin": {
    "claude-talkback-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
